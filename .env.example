# Local development example. Copy to .env if needed.
# Do not commit real secrets or child-identifying data.

APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=Asia/Shanghai
LOG_LEVEL=INFO

# v0.1 defaults to mock providers. Do not commit real API keys.
CHILD_AI_MODEL_PROVIDER=mock
CHILD_AI_CHILD_CHAT_PROFILE=

# Xiaomi Mimo OpenAI-compatible provider. Keep disabled unless explicitly testing.
CHILD_AI_MIMO_ENABLED=false
CHILD_AI_MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
CHILD_AI_MIMO_MODEL=mimo-v2.5-pro
CHILD_AI_MIMO_API_KEY=
CHILD_AI_MIMO_ALLOW_CHILD_DATA=false
CHILD_AI_MIMO_ALLOW_IMAGE=false
CHILD_AI_MIMO_ALLOW_AUDIO=false
CHILD_AI_MIMO_RETENTION_POLICY_CHECKED=false
CHILD_AI_MIMO_MAX_TOKENS=300
CHILD_AI_MIMO_TIMEOUT_MS=30000

# 小白狐 TTS defaults. Keep real VoiceClone disabled unless explicitly testing.
CHILD_AI_TTS_PROVIDER=mock
CHILD_AI_CONVERSATION_TTS_ENABLED=false
CHILD_AI_MIMO_TTS_ENABLED=false
CHILD_AI_MIMO_TTS_API_KEY=
CHILD_AI_MIMO_TTS_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
CHILD_AI_MIMO_TTS_MODEL=mimo-v2.5-tts-voiceclone
CHILD_AI_MIMO_TTS_TIMEOUT_MS=30000
CHILD_AI_MIMO_TTS_ALLOW_CHILD_TEXT=false
CHILD_AI_MIMO_TTS_RETENTION_POLICY_CHECKED=false
CHILD_AI_XIAOBAIHU_VOICE_SAMPLE_PATH=backend/assets/voices/xiaobaohu_voice_v01.wav
CHILD_AI_TTS_CACHE_DIR=backend/storage/tts_cache
CHILD_AI_TTS_PUBLIC_BASE_URL=/media/tts
CHILD_AI_TTS_MAX_TEXT_CHARS=300

# Future backend defaults. The backend is not initialized in S00.
DATABASE_URL=sqlite:///./local_dev.sqlite3
CHILD_DATA_RETENTION_MODE=minimal
PARENT_REPORT_TIME=21:30
