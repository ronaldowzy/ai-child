# Local development example. Copy to .env if needed.
# Do not commit real secrets or child-identifying data.

APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=Asia/Shanghai
LOG_LEVEL=INFO

# Family-beta runtime must use formal providers. Do not commit real API keys.
CHILD_AI_ALLOW_MOCK_RUNTIME=false
CHILD_AI_ALLOW_AUTH_MEMORY_FALLBACK=false
CHILD_AI_MODEL_PROVIDER=mimo
CHILD_AI_CHILD_CHAT_PROFILE=

# Xiaomi Mimo OpenAI-compatible provider. Fill API key locally only.
CHILD_AI_MIMO_ENABLED=true
CHILD_AI_MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
CHILD_AI_MIMO_MODEL=mimo-v2.5-pro
CHILD_AI_MIMO_API_KEY=
CHILD_AI_MIMO_ALLOW_CHILD_DATA=true
CHILD_AI_MIMO_ALLOW_IMAGE=true
CHILD_AI_MIMO_ALLOW_AUDIO=false
CHILD_AI_MIMO_RETENTION_POLICY_CHECKED=true
CHILD_AI_MIMO_MAX_TOKENS=300
CHILD_AI_MIMO_TIMEOUT_MS=30000

# Vision/image understanding uses the native multimodal model, not the pro text model.
CHILD_AI_VISION_PROVIDER=mimo
CHILD_AI_MIMO_VISION_MODEL=mimo-v2.5

# 小白狐 TTS defaults. Runtime uses backend VoiceClone audio, not system TTS.
CHILD_AI_TTS_PROVIDER=mimo
CHILD_AI_CONVERSATION_TTS_ENABLED=true
CHILD_AI_OPENING_TTS_SOFT_TIMEOUT_MS=15000
CHILD_AI_CONVERSATION_STREAM_TTS_SOFT_TIMEOUT_MS=15000
CHILD_AI_MIMO_TTS_ENABLED=true
CHILD_AI_MIMO_TTS_API_KEY=
CHILD_AI_MIMO_TTS_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
CHILD_AI_MIMO_TTS_MODEL=mimo-v2.5-tts-voiceclone
CHILD_AI_MIMO_TTS_TIMEOUT_MS=30000
CHILD_AI_MIMO_TTS_ALLOW_CHILD_TEXT=true
CHILD_AI_MIMO_TTS_RETENTION_POLICY_CHECKED=true
CHILD_AI_XIAOBAIHU_VOICE_SAMPLE_PATH=backend/assets/voices/xiaobaohu_voice_v01.wav
CHILD_AI_TTS_CACHE_DIR=backend/storage/tts_cache
CHILD_AI_TTS_PUBLIC_BASE_URL=/media/tts
CHILD_AI_TTS_MAX_TEXT_CHARS=300

# ASR defaults. Local SenseVoice is the preferred formal provider.
CHILD_AI_ASR_PROVIDER=local_sensevoice
CHILD_AI_ASR_FALLBACK_PROVIDER=mimo
CHILD_AI_LOCAL_SENSEVOICE_ENABLED=true
CHILD_AI_LOCAL_SENSEVOICE_MODEL_PATH=backend/models/asr/sensevoice/model.int8.onnx
CHILD_AI_LOCAL_SENSEVOICE_TOKENS_PATH=backend/models/asr/sensevoice/tokens.txt
CHILD_AI_LOCAL_SENSEVOICE_NUM_THREADS=4
CHILD_AI_LOCAL_SENSEVOICE_USE_ITN=true
CHILD_AI_LOCAL_SENSEVOICE_LANGUAGE=zh
CHILD_AI_MIMO_ASR_ENABLED=true
CHILD_AI_MIMO_ASR_API_KEY=
# If empty, backend ASR reuses CHILD_AI_MIMO_API_KEY, then CHILD_AI_MIMO_TTS_API_KEY.
CHILD_AI_MIMO_ASR_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
# ASR uses mimo-v2.5. Do not set this to the text model mimo-v2.5-pro.
CHILD_AI_MIMO_ASR_MODEL=mimo-v2.5
CHILD_AI_MIMO_ASR_TIMEOUT_MS=30000
CHILD_AI_MIMO_ASR_ALLOW_CHILD_AUDIO=true
CHILD_AI_MIMO_ASR_RETENTION_POLICY_CHECKED=true
CHILD_AI_MIMO_ASR_NO_TRAINING_CONFIRMED=true

# Local PostgreSQL dev database. This password is only for docker-compose.local.yml.
CHILD_AI_DATABASE_URL=postgresql+psycopg://child_ai:child_ai@localhost:5432/child_ai_dev
CHILD_DATA_RETENTION_MODE=minimal
PARENT_REPORT_TIME=21:30
